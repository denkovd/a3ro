# ── Oil Tracker backend ──────────────────────────────────────────
# Postgres connection string (Neon / Supabase / Vercel Postgres —
# use the POOLED string on serverless).
DATABASE_URL=postgres://user:pass@host:5432/oiltracker

# EIA open data key — free, instant: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# For the deferred adapters (leave unset until implemented):
# FRED_API_KEY=        # free: https://fred.stlouisfed.org/docs/api/api_key.html
# ALPHAVANTAGE_API_KEY=# free: https://www.alphavantage.co/support/#api-key
# (yfinance needs no key)
