{
  "name": "@a3ro/oil-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Oil price tracker backend: source adapters, ingestion, resolution, alert rules",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "ingest": "tsx scripts/run-ingest.ts",
    "backfill:oil-prices": "tsx scripts/backfill-oil-prices.ts",
    "run:scores": "tsx scripts/run-scores.ts",
    "run:positioning": "tsx scripts/run-positioning.ts",
    "migrate:alerts": "tsx scripts/migrate.ts migrations/017_alert_rules_seed.sql",
    "migrate": "psql \"$DATABASE_URL\" -f migrations/001_init.sql",
    "migrate:corridors": "psql \"$DATABASE_URL\" -f migrations/002_corridors.sql",
    "migrate:leads": "psql \"$DATABASE_URL\" -f migrations/003_leads.sql",
    "migrate:regime": "psql \"$DATABASE_URL\" -f migrations/004_regime.sql",
    "migrate:scores": "psql \"$DATABASE_URL\" -f migrations/006_scores.sql",
    "migrate:bull": "psql \"$DATABASE_URL\" -f migrations/007_bull.sql",
    "migrate:seasonal": "psql \"$DATABASE_URL\" -f migrations/008_seasonal.sql",
    "migrate:macro": "psql \"$DATABASE_URL\" -f migrations/009_macro.sql",
    "migrate:positioning": "psql \"$DATABASE_URL\" -f migrations/010_positioning.sql",
    "migrate:tape": "psql \"$DATABASE_URL\" -f migrations/011_tape.sql",
    "migrate:thesis": "psql \"$DATABASE_URL\" -f migrations/012_thesis.sql",
    "migrate:earnings": "psql \"$DATABASE_URL\" -f migrations/013_earnings.sql",
    "migrate:earnings-v2": "psql \"$DATABASE_URL\" -f migrations/014_earnings_v2.sql",
    "migrate:bull-strategies": "psql \"$DATABASE_URL\" -f migrations/015_bull_strategies.sql",
    "migrate:gold": "psql \"$DATABASE_URL\" -f migrations/016_gold.sql",
    "verify:regime": "tsx scripts/verify-regime.ts",
    "verify:bull": "tsx scripts/verify-bull.ts",
    "scan:bull": "tsx scripts/run-bull-scan.ts",
    "refresh:universe": "tsx scripts/refresh-universe.ts",
    "migrate:win": "tsx scripts/migrate.ts",
    "run:macro": "tsx scripts/run-macro.ts",
    "backfill:gold": "tsx scripts/backfill-gold.ts",
    "run:gold": "tsx scripts/run-gold.ts",
    "run:gold-flow": "tsx scripts/run-gold-flow.ts",
    "migrate:gold-flow": "tsx scripts/migrate.ts migrations/018_gold_flow.sql",
    "run:earnings-weekly": "tsx scripts/run-earnings-weekly.ts",
    "backfill:earnings": "tsx scripts/run-earnings-backfill.ts",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "pg": "^8.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "tsx": "^4.16.0",
    "typescript": "^5"
  }
}
